{
  "entities": {
    "User": {
      "title": "User",
      "description": "Профиль покупателя или администратора",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "UID из Firebase Auth" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Товар в каталоге",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "type": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "type", "price", "description", "imageUrl", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Заказ покупателя",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID пользователя, сделавшего заказ" },
        "customerInfo": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "deliveryAddress": { "type": "string" }
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["Новый", "В обработке", "Отправлен", "Доставлен", "Отменен"] },
        "paymentStatus": { "type": "string", "enum": ["Ожидает оплаты", "Оплачен", "При получении"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "customerInfo", "items", "totalAmount", "status", "paymentStatus", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Хранит профили пользователей"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Хранит каталог товаров"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Хранит заказы пользователей"
    }
  }
}
